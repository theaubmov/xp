{
  "name": "vue-project",
  "version": "0.0.0",
  "scripts": {
    "fake-api": "nodemon --watch ./fake-api ./fake-api/server.js",
    "dev:mock": "run-p fake-api dev",
    "dev": "vite --port 5000",
    "build:netlify": "vite build",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 4173",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@braks/vue-flow": "^0.4.28",
    "@quasar/extras": "^1.14.2",
    "@types/luxon": "^3.0.0",
    "axios": "^0.27.2",
    "cors": "^2.8.5",
    "luxon": "^3.0.1",
    "pinia": "^2.0.14",
    "quasar": "^2.7.5",
    "serverless-http": "^3.2.0",
    "vue": "^3.2.37",
    "vue-router": "^4.0.16"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "^1.0.10",
    "@rushstack/eslint-patch": "^1.1.0",
    "@types/axios": "^0.14.0",
    "@types/lodash": "^4.14.182",
    "@types/uuid": "^8.3.4",
    "@vitejs/plugin-vue": "^2.3.3",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/eslint-config-typescript": "^11.0.0",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^8.5.0",
    "eslint-plugin-vue": "^9.0.0",
    "json-server": "^0.17.0",
    "nodemon": "^2.0.19",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "sass": "^1.32.12",
    "typescript": "~4.7.4",
    "uuid": "^8.3.2",
    "vite": "^2.9.12",
    "vue-tsc": "^0.38.1"
  }
}
